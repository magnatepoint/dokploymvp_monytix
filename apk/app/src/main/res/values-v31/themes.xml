<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen: black background with centered MONYTIX logo -->
    <style name="Theme.Monytix.Splash" parent="Theme.Monytix">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowSplashScreenBackground">@color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/logo</item>
    </style>
</resources>
