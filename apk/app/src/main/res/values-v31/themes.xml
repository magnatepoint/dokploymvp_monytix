<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash: same background + logo as pre-12 (windowBackground has logo); icon = logo for consistency -->
    <style name="Theme.Monytix.Splash" parent="Theme.Monytix">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowSplashScreenBackground">@color/splash_background_color</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
    </style>
</resources>
